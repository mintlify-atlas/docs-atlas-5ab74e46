  "keyFeatures": [
    "Biographical data entry and management system",
    "Historical Chinese person records database",
    "Office posting and career path tracking",
    "Kinship and social relationship network",
    "Multi-level user roles and permissions",
    "Comprehensive operation audit log",
    "Public REST API for data queries",
    "Code table management system",
    "View table query interface",
    "SQLite export for research datasets"
  ],
  "publicApiSurface": [
    "/api/post_list - Get office positions by category",
    "/api/entry_list - Get entry paths by category",
    "/api/place_list - Search places by name and time",
    "/api/place_belongs_to - Get sub-places by parent ID",
    "/api/office_list_by_name - Search offices by name",
    "/api/entry_list_by_name - Search entry paths by name",
    "/api/query_office_postings - Query office posting records",
    "/api/query_entry_postings - Query people by entry path",
    "/api/query_relatives_2 - Query kinship relationships",
    "/api/get_assoc - Get associations by type code",
    "/api/find_assoc - Search associations by name",
    "/api/query_associates - Query social associations",
    "/api/query_assoc_network - Query social network",
    "/api/query_by_place - Query people by place",
    "/cbdbapi/person - CBDB API v1 person lookup",
    "/api/v2/mutate - Mutation API for data updates"
  ]
